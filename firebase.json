{
  "firestore": [
    {
      "database": "bigquery-aif",
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json"
    }
  ],
  "hosting": {
    "site": "bigquery-aif-schomer",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "function": {
          "functionId": "ssrbigqueryaifschomer",
          "region": "us-central1"
        }
      }
    ]
  }
}
