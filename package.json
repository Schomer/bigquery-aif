{
  "name": "bigquery-aif",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 5800",
    "build": "next build",
    "start": "next start --port ${PORT:-5800}",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "watch:build": "node scripts/watch-build.mjs",
    "test:auth": "node scripts/auth-setup.mjs",
    "test:setup": "node scripts/setup-reference-dataset.mjs",
    "test:run": "node scripts/test-loop.mjs",
    "test:screenshots": "node scripts/capture-screenshots.mjs",
    "test:report": "node scripts/generate-report.mjs",
    "test:all": "node scripts/test-loop.mjs && node scripts/capture-screenshots.mjs && node scripts/generate-report.mjs"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.5",
    "ai": "^7.0.11",
    "firebase": "^12.14.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@types/google.accounts": "^0.0.18",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "playwright": "^1.61.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
